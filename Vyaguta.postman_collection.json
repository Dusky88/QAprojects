              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Parse the response\r",
                  "var jsonData = pm.response.json();\r",
                  "\r",
                  "// 2. Save the ID first\r",
                  "const id = jsonData.id;\r",
                  "pm.environment.set(\"eventId\", id);\r",
                  "\r",
                  "// 3. Status code assertion\r",
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "// 4. Payload assertions\r",
                  "pm.test(\"Event name matches\", function () {\r",
                  "    pm.expect(jsonData.name).to.eql(pm.environment.get(\"eventName\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Description matches\", function () {\r",
                  "    pm.expect(jsonData.description).to.eql(pm.environment.get(\"description\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Link matches\", function () {\r",
                  "    pm.expect(jsonData.link).to.eql(pm.environment.get(\"link\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Event date matches\", function () {\r",
                  "    pm.expect(jsonData.eventDate).to.eql(pm.environment.get(\"eventDate\"));\r",
                  "});\r",
                  "\r",
                  "// 5. ID exists in response\r",
                  "pm.test(\"Event ID exists\", function () {\r",
                  "    pm.expect(jsonData.id).to.exist;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
