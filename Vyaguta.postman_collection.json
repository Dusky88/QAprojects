        {
          "name": "CreateEventWithoutName",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var name = \"{{name}}\"; \r",
                  "var description = \"{{description}}\";\r",
                  "var link = \"{{link}}\";\r",
                  "var eventDate = \"{{2026-05-03}}\";\r",
                  "var bearerToken = \"{{bearerToken}}\";\t"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const Ajv = require('ajv');\r",
                  "const ajv = new Ajv();\r",
                  "\r",
                  "// parse response\r",
                  "var jsonData = pm.response.json();\r",
                  "\r",
                  "// status check\r",
                  "pm.test(\"Status code is 400\", function () {\r",
                  "    pm.response.to.have.status(400);\r",
                  "});\r",
                  "\r",
                  "// error object exists\r",
                  "pm.test(\"Error object exists\", function () {\r",
                  "    pm.expect(jsonData.error).to.exist;\r",
                  "});\r",
                  "\r",
                  "// error code is 400\r",
                  "pm.test(\"Error code is 400\", function () {\r",
                  "    pm.expect(jsonData.error.code).to.eql(400);\r",
                  "});\r",
                  "\r",
                  "// error message is Bad Request\r",
                  "pm.test(\"Error message is Bad Request\", function () {\r",
                  "    pm.expect(jsonData.error.message).to.eql(\"Bad Request\");\r",
                  "});\r",
                  "\r",
                  "// details array exists and is not empty\r",
                  "pm.test(\"Details array exists\", function () {\r",
                  "    pm.expect(jsonData.error.details).to.be.an(\"array\").that.is.not.empty;\r",
                  "});\r",
                  "\r",
                  "// details message says name is required\r",
                  "pm.test(\"Details says name is required\", function () {\r",
                  "    pm.expect(jsonData.error.details[0].message).to.eql(\"\\\"name\\\" is required\");\r",
                  "});\r",
                  "\r",
                  "// param points to name field\r",
                  "pm.test(\"Param is name\", function () {\r",
                  "    pm.expect(jsonData.error.details[0].param).to.include(\"name\");\r",
                  "});\r",
                  "\r",
                  "// schema\r",
                  "var schema = {\r",
                  "    type: \"object\",\r",
                  "    properties: {\r",
                  "        error: {\r",
                  "            type: \"object\",\r",
                  "            properties: {\r",
                  "                code: { type: \"number\" },\r",
                  "                message: { type: \"string\" },\r",
                  "                details: {\r",
                  "                    type: \"array\",\r",
                  "                    items: {\r",
                  "                        type: \"object\",\r",
                  "                        properties: {\r",
                  "                            message: { type: \"string\" },\r",
                  "                            param: {\r",
                  "                                type: \"array\",\r",
                  "                                items: { type: \"string\" }\r",
                  "                            }\r",
                  "                        },\r",
                  "                        required: [\"message\", \"param\"]\r",
                  "                    }\r",
                  "                }\r",
                  "            },\r",
                  "            required: [\"code\", \"message\", \"details\"]\r",
                  "        }\r",
                  "    },\r",
                  "    required: [\"error\"]\r",
                  "};\r",
                  "\r",
                  "// validate schema\r",
                  "pm.test(\"Schema is valid\", function () {\r",
                  "    pm.expect(ajv.validate(schema, jsonData)).to.be.true;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
